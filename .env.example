# UI flags
NEXT_PUBLIC_TRAXR_ENABLED=true

# Runtime mode
TRAXR_USE_SQLITE=false
TRAXR_FALLBACK_SAMPLE=false

# Local data integration (dev only)
# These paths are environment-specific and should not be committed as data.
TRAXR_LOCAL_DATA_DIR=./data
# TRAXR_LOCAL_POOLS_PATH=

# API limits
TRAXR_API_LIMIT=200
TRAXR_API_MAX_LIMIT=2000

# Optional diagnostics
TRAXR_TIMINGS=false

# NodeZero integration
# Required for fetch/enrichment flows that access protected datasets or RPC.
# NODEZERO_API_KEY=
# NODEZERO_RPC_KEY=
NODEZERO_RPC_URL=https://nodezero.crosswalk.pro/rpc-internal
